# === Сайт ===
SITE_URL=https://xstreamka.dev

# === Pay Service ===
LISTEN_PORT=8090

# === PostgreSQL ===
DB_PORT=5433
DB_USER=payservice
DB_PASS=your_secure_password
DB_NAME=payservice

# === Робокасса ===
ROBOKASSA_LOGIN=your_merchant_login
ROBOKASSA_PASS1=your_password_1
ROBOKASSA_PASS2=your_password_2
ROBOKASSA_TEST_MODE=true
ROBOKASSA_HASH_ALGO=md5

# === Webhook ===
# Общий секрет для подписи (одинаковый на pay-service и VPN-панели)
# Сгенерировать: openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-random-64-hex-chars

# === Admin UI ===
ADMIN_USER=admin

# Пароль: либо plaintext (для dev), либо bcrypt-хэш (для продакшена).
# Если заданы оба — используется хэш.
# Генерация хэша:
#   htpasswd -bnBC 12 "" 'your_password' | tr -d ':\n' | sed 's/^\$2y/\$2a/'
# или через Go: bcrypt.GenerateFromPassword([]byte("..."), bcrypt.DefaultCost)
ADMIN_PASSWORD=admin
# ADMIN_PASSWORD_HASH=$2a$12$...

# Секрет для подписи session-cookie (>= 32 байта)
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=change-me-to-random-64-hex-chars
